# =============================================================================
# Action's Odds — Environment Variables (template)
# =============================================================================
# Copy this file to .env for local dev (never commit .env)
# Production: set these in Railway → Project → Variables
# =============================================================================

# ─── Supabase ───
SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_ANON_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY
SUPABASE_SERVICE_KEY=sb_secret_YOUR_SECRET_KEY

# ─── Stripe (TEST mode during development) ───
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY

# Stripe webhook signing secret — set AFTER creating webhook in Stripe dashboard
STRIPE_WEBHOOK_SECRET=

# ─── Resend (password reset emails) ───
RESEND_API_KEY=re_YOUR_API_KEY

# ─── App ───
PUBLIC_URL=https://actionsodds.com

# ─── Existing keys already in use ───
ODDS_API_KEY=YOUR_ODDS_API_KEY
# ANTHROPIC_API_KEY=
